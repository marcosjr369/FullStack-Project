generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(cuid())
  firstName String
  lastName String?
  email String @unique
  clerkUserId String @unique
  imgUrl String?

  createdAt DateTime @default(now())
  update DateTime @updatedAt

  @@map("users")
}